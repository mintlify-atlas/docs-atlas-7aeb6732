  "keyFeatures": [
    "Modern 64-bit kernel with pre-emptive multi-threading",
    "Custom JavaScript and WebAssembly engine (LibJS)",
    "Full web browser with LibWeb rendering engine",
    "Complete GUI with WindowServer and desktop environment",
    "POSIX compatibility with custom utilities and shell",
    "Custom C++ standard library (AK) and LibC implementation",
    "Security features including pledge, unveil, and W^X memory",
    "Network stack with IPv4, TCP, UDP, and application protocols",
    "Rich application suite including IDE, text editors, and games",
    "Multi-architecture support (x86-64, Arm, RISC-V)"
  ],
  "publicApiSurface": [
    "AK (custom C++ standard library)",
    "LibCore (event loop, OS abstraction)",
    "LibGUI (graphical user interface)",
    "LibGfx (2D graphics and image decoding)",
    "LibWeb (web rendering engine)",
    "LibJS (JavaScript engine)",
    "LibWasm (WebAssembly implementation)",
    "LibHTTP (HTTP/1.1 client)",
    "LibTLS (TLS implementation)",
    "LibAudio (audio playback)",
    "LibIPC (inter-process communication)",
    "Kernel syscalls (pledge, unveil, open, read, write, etc.)",
    "WindowServer protocol",
    "AudioServer protocol"
  ]
